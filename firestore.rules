rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isPremium() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan in ['core','premium','corporate'];
    }
    function notBlocked() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false;
    }

    // Users
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Onboarding
    match /onboarding/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Belief check-ins
    match /beliefCheckins/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // I AM statements
    match /iamStatements/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Belief reframes
    match /beliefReframes/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && notBlocked();
      allow delete: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Morning check-ins
    match /morningCheckins/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Midday check-ins
    match /middayCheckins/{docId} {
      allow read, write: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Intentions
    match /intentions/{docId} {
      allow read, write: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // SATS sessions
    match /satsSessions/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // Celebrations
    match /celebrations/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // Pattern breaks
    match /patternBreaks/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && notBlocked();
      allow update, delete: if isAdmin();
    }

    // Challenges
    match /challenges/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Weekly reviews
    match /weeklyReviews/{docId} {
      allow read, write: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Journal entries
    match /journalEntries/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Content
    match /meditations/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /breathwork/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /asana/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /affirmations/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Master library, premium only
    match /masterLibrary/{docId} {
      allow read: if isPremium() || isAdmin();
      allow write: if isAdmin();
    }

    // Content plays
    match /contentPlays/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // Income intentions
    match /incomeIntentions/{docId} {
      allow read, write: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Income entries
    match /incomeEntries/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // Community posts
    match /posts/{postId} {
      allow read: if isAuth() && (resource.data.status == 'approved' || resource.data.status == 'featured' || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && notBlocked();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Post likes
    match /postLikes/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Comments
    match /comments/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && notBlocked();
      allow delete: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Subscriptions / transactions
    match /transactions/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // Refresh tokens
    match /refreshTokens/{docId} {
      allow read, write: if false;
    }

    // Notification logs
    match /notificationLogs/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow write: if isAdmin();
    }

    // Admin audit logs
    match /adminAuditLogs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Tasks
    match /tasks/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Energy vampires
    match /energyVampires/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Energy shields
    match /energyShields/{docId} {
      allow read, write: if isAuth() && resource.data.uid == request.auth.uid || isAdmin();
    }

    // Custom shields
    match /customShields/{docId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // User settings
    match /userSettings/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
